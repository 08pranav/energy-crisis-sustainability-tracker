# App
NODE_ENV=development
PORT=5000
APP_NAME=energy-crisis-api
API_BASE_PATH=/api
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/energy_crisis_tracker
MONGODB_DB_NAME=energy_crisis_tracker

# Auth
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Security / Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120
CORS_ORIGINS=http://localhost:5173

# External Data
IEA_API_KEY=replace_with_iea_key
IEA_BASE_URL=https://api.iea.org
BP_DATASET_PATH=./src/scripts/data/bp_energy.csv

# Realtime / Scheduler
POLLING_INTERVAL_MS=30000
CRON_REFRESH_SCHEDULE=*/30 * * * *

# Upload
MAX_UPLOAD_SIZE_MB=25
UPLOAD_DIR=uploads
